# ZenteiQ Real-Time Log Monitor — Development Environment

# HTTP Server
PORT=3000

# JWT Authentication (use at least 32 chars for production)
JWT_SECRET=YOUR_SECRET_KEY
JWT_EXPIRES_IN=24h

# File Monitoring
POLL_INTERVAL_MS=250
TAIL_CHUNK_SIZE=4096

# File Access Control
LOGS_DIR=YOUR_LOGS_DIRECTORY
ALLOWED_EXTENSIONS=.log,.txt
